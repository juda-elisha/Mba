{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": ".vercel/output/functions",
    "baseUrl": "..",
    "paths": {
      "@workspace/db": ["lib/db/src/index.ts"],
      "@workspace/api-zod": ["lib/api-zod/src/index.ts"],
      "@workspace/api-client-react": ["lib/api-client-react/src/index.ts"]
    }
  },
  "include": ["server.ts", "../artifacts/api-server/src/**/*", "../lib/db/src/**/*", "../lib/api-zod/src/**/*"]
}
