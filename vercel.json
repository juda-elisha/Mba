{
  "version": 2,
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm run typecheck:libs && pnpm --filter @workspace/rewards-app run build",
  "outputDirectory": "artifacts/rewards-app/dist/public",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/server" },
    { "source": "/rewardsriver/:path*", "destination": "/api/server" },
    { "source": "/:path*", "destination": "/index.html" }
  ]
}
